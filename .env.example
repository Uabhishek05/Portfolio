# Kount Device Data Collection
# Set to true to enable script injection.
VITE_KOUNT_ENABLED=false

# Your Kount merchant ID.
VITE_KOUNT_MERCHANT_ID=

# Kount collector endpoint provided by your Kount account setup.
# Example format: https://<your-kount-endpoint>/collect/sdk
VITE_KOUNT_COLLECTOR_URL=

# Contact form (Formspree)
# Create a form in Formspree and paste endpoint like:
# https://formspree.io/f/xxxxxxxx
VITE_FORMSPREE_ENDPOINT=
